# ─── Web (apps/web/.env.local) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://observal.app

# ─── Supabase Edge Functions (set in Supabase dashboard → Edge Functions secrets) ─
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_xxxxxxxx
ALERTS_FROM_EMAIL=Observal <alerts@observal.app>
APP_URL=https://observal.app
CRON_SECRET=generate-a-random-secret-for-check-collectors

# ─── Factory / dev only ────────────────────────────────────────────────────────
FACTORY_API_SECRET=change-me-in-production
