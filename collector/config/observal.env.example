# Observal Collector — production environment
# Copy to /etc/observal/observal.env

SUPABASE_URL=https://your-project.supabase.co
OBSERVAL_DATA_DIR=/var/lib/observal
OBSERVAL_IDENTITY_PATH=/etc/observal/identity.json

# Set to 1 only for dev/lab (auto-generates identity if missing)
# OBSERVAL_DEV=0
